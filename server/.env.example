# Copy to `.env` in this folder (`server/.env`) and fill in your key.
# https://console.anthropic.com/ — API keys must never be committed.

ANTHROPIC_API_KEY=

# Optional — override the default model
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional — cloud text-to-speech for “Read aloud” in the command bar (OpenAI).
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# Optional: opus (smaller/faster download than mp3) — mp3, opus, aac, flac, wav, pcm
# OPENAI_TTS_FORMAT=mp3
