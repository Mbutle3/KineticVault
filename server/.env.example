# Copy to `.env` in this folder (`server/.env`) and fill in your key.
# https://console.anthropic.com/ — API keys must never be committed.

ANTHROPIC_API_KEY=

# Optional — override the default model
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional — cloud text-to-speech for “Read aloud” in the command bar (OpenAI).
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# Optional: opus (smaller/faster download than mp3) — mp3, opus, aac, flac, wav, pcm
# OPENAI_TTS_FORMAT=mp3

# Optional — safety for demos / public repo.
# If set, all /api/* requests require header `x-kv-token: <value>` (or `Authorization: Bearer <value>`).
# KV_API_TOKEN=
#
# Optional — safety default.
# By default, the real API will refuse to start unless KV_API_TOKEN is set.
# Set KV_REQUIRE_TOKEN=0 only for insecure localhost-only dev.
# KV_REQUIRE_TOKEN=1
#
# Optional — cost guard for AI endpoints (per client IP, per minute).
# KV_AI_RATE_LIMIT_PER_MIN=60
#
# Optional — production-ish knobs (for non-dev usage).
# KV_CORS_ORIGINS=http://localhost:5173
# KV_BIND_HOST=127.0.0.1
# KV_PORT=8000
